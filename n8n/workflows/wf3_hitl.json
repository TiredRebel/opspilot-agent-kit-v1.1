        "operation": "sendMessage",
        "chatId": "PLACEHOLDER_OPS_CHAT_ID",
        "text": "={{ '🎫 <b>Ticket needs review</b> — confidence ' + Math.round(Number($json.confidence) * 100) + '%\\n\\n<i>Answer:</i>\\n' + $json.answer + '\\n\\n<i>Sources:</i>\\n' + ($json.sources || []).map(s => '• ' + s).join('\\n') + '\\n\\nTICKET-ID: ' + $json.ticket_id }}",
