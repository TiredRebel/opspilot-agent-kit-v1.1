        "additionalFields": {
          "parse_mode": "HTML"
        },
        "inlineKeyboard": {
          "rows": [
            {
              "row": {
                "buttons": [
                  {
                    "text": "✅ Approve",
                    "additionalFields": {
                      "callback_data": "=apr|{{ $json.ticket_id }}"
                    }
                  },
                  {
                    "text": "✏️ Edit",
                    "additionalFields": {
                      "callback_data": "=edt|{{ $json.ticket_id }}"
                    }
                  },
                  {
                    "text": "❌ Reject",
                    "additionalFields": {
                      "callback_data": "=rej|{{ $json.ticket_id }}"
                    }
                  }
                ]
              }
            }
          ]
