    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT m.content AS answer, t.external_ref, t.source FROM messages m JOIN tickets t ON t.id = m.ticket_id WHERE m.ticket_id = $1 AND m.role = 'ai_draft' ORDER BY m.created_at DESC LIMIT 1",
        "options": {
          "queryReplacement": "={{ [$('Execute Workflow Trigger').item.json.ticket_id] }}"
        }
      },
      "id": "1fae5d01-6ce6-4d32-b064-26845c4705d2",
