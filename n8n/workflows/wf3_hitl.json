        "language": "javaScript",
        "jsCode": "const source = $json.source;\nconst externalRef = $json.external_ref;\nlet chatId = null;\nif (source === 'telegram' && externalRef) {\n  chatId = externalRef.split(':')[0];\n}\nreturn { chat_id: chatId, answer: $json.answer };"
