# --- Database ---
POSTGRES_USER=opspilot
POSTGRES_PASSWORD=changeme
POSTGRES_DB=opspilot
POSTGRES_PORT=5432
DATABASE_URL=postgresql://opspilot:changeme@postgres:5432/opspilot

# --- RAG service ---
# 8000 is often taken by other local services (see wiki/gotchas.md #8) — 8010 is a safer default.
RAG_API_PORT=8010
# Level for the service's structured app logs (stderr, key=value lines): DEBUG|INFO|WARNING|...
LOG_LEVEL=INFO

# --- LLM providers (services/rag/app/llm/ package only) ---
LLM_PROVIDER=fake
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
# Optional: a personal ollama.com API key. When set, the ollama provider talks directly to
# https://ollama.com/v1 instead of the local daemon — needed for `:cloud` models if the local
# daemon's account doesn't hold the separate ollama.com subscription plan.
OLLAMA_API_KEY=
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text
DAILY_BUDGET_USD=2.00

# --- Confidence gate ---
CONFIDENCE_THRESHOLD=0.70

# --- n8n (reusing the existing local instance, not started by this project's compose) ---
N8N_API_URL=http://localhost:5678
N8N_API_KEY=
WEBHOOK_URL=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_OPS_CHAT_ID=

# --- Notion (P4) ---
NOTION_API_KEY=
NOTION_PAGE_ID=

# --- RabbitMQ (async messaging — ADR-007) ---
# Broker credentials; the n8n "RabbitMQ - OpsPilot" credential uses the same pair against
# localhost:${RABBITMQ_PORT} (n8n runs outside compose — gotcha #1).
RABBITMQ_USER=opspilot
RABBITMQ_PASSWORD=changeme
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
