            "typeValidation": "strict",
            "version": 2
          },
          "conditions": [
            {
              "id": "cond-is-ops-chat-1",
              "leftValue": "={{ String($json.message.chat.id) }}",
              "rightValue": "PLACEHOLDER_OPS_CHAT_ID",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            },
            {
              "id": "cond-is-reply-1",
              "leftValue": "={{ !!$json.message.reply_to_message }}",
              "rightValue": "",
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "3bf1e5a9-e9d4-4cd1-a96c-49bb0c7975ae",
      "name": "Is Ops Reply",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        0,
        620
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "language": "javaScript",
        "jsCode": "const replyText = ($json.message.reply_to_message && $json.message.reply_to_message.text) || '';\nconst match = replyText.match(/TICKET-ID:([0-9a-fA-F-]+)/);\nreturn {\n  mode: 'edit_reply',\n  ticket_id: match ? match[1] : null,\n  corrected_text: $json.message.text || ''\n};"
      },
      "id": "0631f406-ff8f-4b3a-ae3d-b50993a77f88",
      "name": "Prepare Edit Reply Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        260,
        620
      ]
    },
    {
      "parameters": {
