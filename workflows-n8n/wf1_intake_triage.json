        "language": "javaScript",
        "jsCode": "const msg = $json.message || {};\nconst chatId = msg.chat ? msg.chat.id : null;\nconst messageId = msg.message_id;\nreturn {\n  source: 'telegram',\n  external_ref: `${chatId}:${messageId}`,\n  subject: null,\n  body: msg.text || ''\n};"
      },
