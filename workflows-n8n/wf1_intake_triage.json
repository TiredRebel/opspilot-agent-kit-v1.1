      "position": [
        0,
        420
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "language": "javaScript",
        "jsCode": "const data = ($json.callback_query && $json.callback_query.data) || '';\nconst [action, ticket_id] = data.split('|');\nreturn {\n  mode: 'callback',\n  action,\n  ticket_id,\n  callback_query_id: $json.callback_query.id\n};"
      },
      "id": "fdad3bc3-913f-4dc3-8550-69647d9957f9",
